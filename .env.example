# ChatGPT Credentials (required for testing)
CHATGPT_USERNAME=your_email@example.com
CHATGPT_PASSWORD=your_password

# Browser Configuration
BROWSER_TYPE=chromium  # chromium, firefox, webkit
HEADLESS=false  # Set to true for headless mode
TIMEOUT_MS=30000

# GPT Interaction
DEFAULT_MESSAGE=你好gpt
WAIT_FOR_RESPONSE_SEC=10

# URLs (usually don't need to change)
CHATGPT_LOGIN_URL=https://chat.openai.com/auth/login
CHATGPT_CHAT_URL=https://chat.openai.com/

# Logging
LOG_LEVEL=INFO
SCREENSHOTS_DIR=./screenshots